# ------------------------------------------------------------------------------
# Open WebUI Docker Stack Configuration Environment Variables
# Copy this file to .env and customize values as needed.
# ------------------------------------------------------------------------------

# Service ports
PORT=8080
OLLAMA_PORT=11434
PORT_DASHBOARD=8000

# Open WebUI Security Key (Highly recommended to change this to a long random string)
OPEN_WEBUI_SECRET_KEY=webui-super-secret-session-signing-token-change-me

# PostgreSQL Database Configuration
DB_HOST=db
DB_PORT=5432
DB_USER=webui
DB_PASSWORD=securepasswordchangeit
DB_NAME=webui

# Ollama API Configuration
# - For Dockerized Ollama: http://ollama:11434
# - For Native Ollama (e.g. macOS Host): http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# Data Persistence Directory
# - For Local Deployments: ./data (will create a directory in the project folder)
# - For RunPod Deployments: /workspace (preserves data when upgrading/downgrading GPUs)
DATA_DIR=./data

# OpenClaw AI Agent Gateway Configuration
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_TOKEN=secure-gateway-token-change-me


